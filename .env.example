# Copy this file to .env and fill in your key(s).
# .env is in .gitignore — never commit the real key.

# ── AI provider selection ─────────────────────────────────────────────────────
# Controls which AI engine powers the chat page.
# Options: anthropic (default) | gemini
AI_PROVIDER=anthropic

# ── Anthropic (default) ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
# Model used: claude-sonnet-4-6
ANTHROPIC_API_KEY=your_key_here

# ── Google Gemini (free tier available) ───────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# Model used: gemini-2.0-flash
# Set AI_PROVIDER=gemini above to activate.
# GOOGLE_API_KEY=your_key_here

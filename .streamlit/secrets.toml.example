# Copy this to .streamlit/secrets.toml for local dev.
# On Streamlit Cloud, enter these values in the Secrets dashboard instead.
# secrets.toml is in .gitignore — never commit the real keys.

AI_PROVIDER = "anthropic"          # or "gemini"
ANTHROPIC_API_KEY = "your_key_here"
# GOOGLE_API_KEY = "your_key_here"
